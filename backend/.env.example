# ── ProjectHub Backend — Variáveis de Ambiente ────────────────────────────────
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA versione o .env com credenciais reais!

# App
APP_NAME=ProjectHub API
APP_VERSION=1.0.0
DEBUG=false

# Database (Supabase PostgreSQL)
# Formato: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.xxxxxxxxxxx.supabase.co:5432/postgres

# JWT
SECRET_KEY=troque-por-uma-chave-aleatoria-de-256-bits
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (Upstash — opcional, desativa cache se vazio)
REDIS_URL=rediss://default:SEU_TOKEN@sly-xxxxx.upstash.io:6379

# GitHub API (opcional, aumenta rate limit)
GITHUB_TOKEN=ghp_SEUTOKEN

# CORS — origens permitidas separadas por vírgula
ALLOWED_ORIGINS=https://seu-app.vercel.app,http://localhost:5173
